    {
      "parameters": {
        "operation": "executeQuery",
        "query": "CREATE EXTENSION IF NOT EXISTS pgcrypto;\n\nCREATE TABLE IF NOT EXISTS usuarios (\n  id SERIAL PRIMARY KEY,\n  nombre VARCHAR(100) DEFAULT 'Usuario',\n  email VARCHAR(255),\n  password TEXT,\n  created_at TIMESTAMP DEFAULT NOW()\n);\n\nALTER TABLE usuarios ADD COLUMN IF NOT EXISTS email VARCHAR(255);\nALTER TABLE usuarios ADD COLUMN IF NOT EXISTS password TEXT;\nCREATE UNIQUE INDEX IF NOT EXISTS usuarios_email_unique ON usuarios (LOWER(email));",
        "options": {}
      },
      "id": "780ecfbc-4a19-4517-bb3c-33fac0959206",
      "name": "crear-tablas-auth",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        224,
        0
      ],
      "credentials": {
        "postgres": {
          "id": "f7EdNg44IQ5OIj14",
          "name": "Postgres account 4"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH nuevo AS (\n  INSERT INTO usuarios (nombre, email, password)\n  VALUES ($1, LOWER($2), crypt($3, gen_salt('bf')))\n  ON CONFLICT (LOWER(email)) DO NOTHING\n  RETURNING id, nombre, email\n)\nSELECT id, nombre, email, true AS ok FROM nuevo\nUNION ALL\nSELECT NULL::int, NULL, LOWER($2), false AS ok\nWHERE NOT EXISTS (SELECT 1 FROM nuevo);",
        "options": {
          "queryReplacement": "={{ $json.body.nombre || 'Usuario' }},{{ $json.body.email }},{{ $json.body.password }}"
        }
      },
      "id": "6f0174cb-ce58-4699-a1f1-26ba46dbab52",
      "name": "registrar-usuario",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
