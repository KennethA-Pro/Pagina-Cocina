        0
      ],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "f7EdNg44IQ5OIj14",
          "name": "Postgres account 4"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const r = $input.first().json || {};\nif (r.ok === true && r.id) {\n  return [{ json: { ok: true, usuario_id: r.id, nombre: r.nombre, email: r.email, mensaje: 'Usuario registrado correctamente' } }];\n}\nreturn [{ json: { ok: false, mensaje: 'El email ya está registrado' } }];"
      },
